# Server
ADDRESS=:8080
WEBDAV_PREFIX=/
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
TLS_CERT_FILE=
TLS_KEY_FILE=
SHUTDOWN_TIMEOUT=10s

# S3 / MinIO
# Accepts host:port or full URL (http/https). If scheme is specified, S3_SECURE is inferred.
S3_ENDPOINT=s3.amazonaws.com
# Leave S3_REGION empty to auto-detect the correct bucket region (recommended)
S3_REGION=
S3_BUCKET=your-bucket
S3_ACCESS_KEY_ID=YOUR_ACCESS_KEY
S3_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
S3_USE_PATH_STYLE=false
S3_SECURE=true

# HTTP transport pool tuning for S3 client
S3_MAX_IDLE_CONNS=2048
S3_MAX_IDLE_CONNS_PER_HOST=1024

# FS options
# Max in-memory buffer for writes before upload (bytes). Small files 50-300KB fit well.
UPLOAD_BUFFER_LIMIT=8388608
